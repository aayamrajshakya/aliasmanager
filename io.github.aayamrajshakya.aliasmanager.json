{
    "app-id": "io.github.aayamrajshakya.aliasmanager",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "alias-manager",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=~/.bashrc",
        "--filesystem=~/.bash_history:ro"
    ],
    "modules": [
        {
            "name": "alias-manager",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/aayamrajshakya/aliasmanager",
                    "tag": "v1.0.2",
                    "commit": "75895788c36a3be6020269dacb6249711d81c998"
                }
            ]
        }
    ]
}