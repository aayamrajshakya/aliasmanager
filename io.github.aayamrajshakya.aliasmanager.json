{
    "app-id": "io.github.aayamrajshakya.aliasmanager",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "//!": "!!!!!!Also update the GNOME version in ./.github/workflows/flatpak.yml",
    "sdk": "org.gnome.Sdk",
    "command": "alias-manager",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=~/.bashrc"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "alias-manager",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/aayamrajshakya/aliasmanager",
                    "tag": "v1.0.1",
                    "commit": "ab9b17f107cee9d781c0ef44ca49a9448245577a"
                }
            ]
        }
    ]
}